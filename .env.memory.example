# Project memory (Hindsight) via OmniRoute — copy to .env.memory and `source` it.
# See docs/PROJECT_MEMORY.md for details and how to verify with `llm-gate probe`.
export HINDSIGHT_API_LLM_PROVIDER=openai
export HINDSIGHT_API_LLM_BASE_URL=http://localhost:20128/v1
export HINDSIGHT_API_LLM_API_KEY="${OPENAI_API_KEY}"
export HINDSIGHT_API_LLM_MODEL=openrouter/tencent/hy3:free
